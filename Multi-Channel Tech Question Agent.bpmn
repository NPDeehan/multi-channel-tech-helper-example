<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Multi-Channel-Agent" name="Multi-Channel-Agent" isExecutable="true">
    <bpmn:sequenceFlow id="Flow_0jt0w1f" sourceRef="Activity_1jbvj8d" targetRef="Event_14an6hl" />
    <bpmn:sequenceFlow id="Flow_0siqvmv" sourceRef="StartEvent_1" targetRef="Activity_1jbvj8d" />
    <bpmn:startEvent id="StartEvent_1" name="Get Question About tech Stuff">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="get-question-about-tech-stuff-1ibjovl" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0siqvmv</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_14an6hl" name="Question About Tech Stuff Answered">
      <bpmn:incoming>Flow_0jt0w1f</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:adHocSubProcess id="Activity_1jbvj8d" name="Tech Question Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="0" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-6" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are **TaskAgent**, a helpful, generic chat agent that can handle a wide variety of customer requests using your own domain knowledge **and** any tools explicitly provided to you at runtime.&#10;&#10;Your goal is to provide an answer to questoins about our tech stuff. Make sure to answer any followup questoins that might also be asked.&#10;&#10;Any communication to the user must go throught he tools provided. &#10;&#10;If tools are provided, you should prefer them instead of guessing an answer. You can call the same tool multiple times by providing different input values. Don&#39;t guess any tools which were not explicitly configured. If no tool matches the request, try to generate an answer. If you&#39;re not able to find a good answer, return with a message stating why you&#39;re not able to.&#10;&#10;Wrap minimal, inspectable reasoning in *exactly* this XML template:&#10;&#10;&#60;thinking&#62;&#10;&#60;context&#62;…briefly state the customer’s need and current state…&#60;/context&#62;&#10;&#60;reflection&#62;…list candidate tools, justify which you will call next and why…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;Reveal **no** additional private reasoning outside these tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=string(question)" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0siqvmv</bpmn:incoming>
      <bpmn:incoming>Flow_1890yp5</bpmn:incoming>
      <bpmn:outgoing>Flow_0jt0w1f</bpmn:outgoing>
      <bpmn:serviceTask id="Activity_1wvern9" name="Get List of Tech Stuff" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this tool in order to get a list of our tech stuff.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://api.restful-api.dev/objects" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="=false" target="ignoreNullValues" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:userTask id="Activity_1lnicu6" name="Show Answer to Question">
        <bpmn:documentation>Use this tool in order to show the asnwer to the user's question. Be aware you maybe also get followup questoins you should respond here to answer those questions</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="show-answer-to-question-1hiz3ni" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.answerToQuestion, &#34;This is the answer to the question the user has asked formated in markdown&#34;)" target="answerToQuestion" />
            <zeebe:output source="={&#10;  &#34;followupQuestion&#34; : followupQuestion&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:serviceTask id="Activity_07bfoi2" name="Show Answer in Slack" zeebe:modelerTemplate="io.camunda.connectors.Slack.v1" zeebe:modelerTemplateVersion="8" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this tool in order to send a response to a user who is communicating over slack. Remeber that slack has specific format requirements.
When formatting messages for Slack, use Slack's mrkdwn syntax (NOT standard markdown):

- Bold: *single asterisks* (not **double**)
- Italic: _underscores_ (not *asterisks*)
- Strikethrough: ~tildes~
- Inline code: `backticks`
- Code blocks: ```triple backticks``` (no language hint — Slack ignores it)
- Blockquote: &gt; at the start of the line
- Bullet lists: use • or - at the start of a line (Slack does not render `*` as bullets)
- Numbered lists: write "1. ", "2. " manually — Slack has no auto-numbering
- Links: &lt;https://example.com|link text&gt; (angle brackets, pipe-separated)
- User mention: &lt;@USER_ID&gt;
- Channel mention: &lt;#CHANNEL_ID&gt;
- Line breaks: use real newlines (\n), not &lt;br&gt;

Do NOT use:
- Markdown headings (#, ##, ###) — they render as literal text
- Tables — Slack does not support them; use aligned text or a bulleted list
- Nested lists with deep indentation — rendering is unreliable
- HTML tags

Keep messages concise. Slack is a conversational medium, not a document. Prefer short paragraphs separated by blank lines over long blocks of text.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:slack:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="{{secrets.SLACK_HAWK_OATH_TOKEN}}" target="token" />
            <zeebe:input source="chat.postMessage" target="method" />
            <zeebe:input source="plainText" target="data.messageType" />
            <zeebe:input source="=fromAi(toolCall.answerToQuestion, &#34;This is the answer to the question the user has asked.&#34;)" target="data.text" />
            <zeebe:input source="=slackRequest.channelId" target="data.channel" />
            <zeebe:input source="=slackRequest.threadTs" target="data.thread" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="8" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.Slack.v1" />
            <zeebe:header key="resultVariable" value="responseToPost" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_1xv0jz4</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:intermediateCatchEvent id="Event_0vckndl" name="Response" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.IntermediateCatchEvent.v1" zeebe:modelerTemplateVersion="7" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:properties>
            <zeebe:property name="inbound.type" value="io.camunda:slack-webhook:1" />
            <zeebe:property name="inbound.context" value="{{secrets.SLACK_HAWK_WEBHOOK_ID}}" />
            <zeebe:property name="inbound.slackSigningSecret" value="{{secrets.SLACK_HAWK_SIGINING_SECRET}}" />
            <zeebe:property name="inbound.verificationExpression" value="=if (body.type != null and body.type = &#34;url_verification&#34;) then {body:{&#34;challenge&#34;:body.challenge}, statusCode: 200} else null" />
            <zeebe:property name="activationCondition" value="=request.body.event.type = &#34;message&#34;&#10; and request.body.event.thread_ts != null&#10; and request.body.event.client_msg_id != null&#10; and request.body.event.bot_id = null" />
            <zeebe:property name="consumeUnmatchedEvents" value="false" />
            <zeebe:property name="correlationKeyExpression" value="=string(request.body.event.thread_ts)" />
            <zeebe:property name="deduplicationModeManualFlag" value="false" />
            <zeebe:property name="deduplicationMode" value="AUTO" />
            <zeebe:property name="resultVariable" value="slackResponsInFull" />
            <zeebe:property name="resultExpression" value="={&#10;  &#34;toolCallResult&#34; : {&#10;    &#34;followUpText&#34;: request.body.event.text,&#10;    &#34;followUpUser&#34;: request.body.event.user&#10;  }&#10;}" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_03c6lz8</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_094u5ql" messageRef="Message_1ej24bd" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1xv0jz4" sourceRef="Activity_07bfoi2" targetRef="Gateway_000w0oi" />
      <bpmn:sequenceFlow id="Flow_03c6lz8" sourceRef="Gateway_000w0oi" targetRef="Event_0vckndl" />
      <bpmn:eventBasedGateway id="Gateway_000w0oi">
        <bpmn:incoming>Flow_1xv0jz4</bpmn:incoming>
        <bpmn:outgoing>Flow_03c6lz8</bpmn:outgoing>
        <bpmn:outgoing>Flow_1p8hauj</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_038j3bw" name="Wait 5 Mins for a response">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;SystemMessage&#34; : &#34;Waited for 5 mins, but there&#39;s no response.&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1p8hauj</bpmn:incoming>
        <bpmn:timerEventDefinition id="TimerEventDefinition_0piytff">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4M</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1p8hauj" sourceRef="Gateway_000w0oi" targetRef="Event_038j3bw" />
      <bpmn:boundaryEvent id="Event_11b0w9b" name="Wait 5 Mins for a response" attachedToRef="Activity_1lnicu6">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;SystemMessage&#34; : &#34;Waited for 5 mins, but there&#39;s no response.&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:timerEventDefinition id="TimerEventDefinition_01nll7p">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:boundaryEvent>
      <bpmn:serviceTask id="Activity_1ftg0az" name="Query Company Information" zeebe:modelerTemplate="Template_148eei5" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this tool in order to get any information on policy or company or product specific questions you might have.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:embeddings-vector-database:1" retries="0" />
          <zeebe:ioMapping>
            <zeebe:input source="retrieveDocumentOperation" target="vectorDatabaseConnectorOperation.operationType" />
            <zeebe:input source="=fromAi(toolCall.query, &#34;This is the query you&#39;re making to the vector database&#34;)" target="vectorDatabaseConnectorOperation.query" />
            <zeebe:input source="=5" target="vectorDatabaseConnectorOperation.documentLimit" />
            <zeebe:input source="bedrockModelProvider" target="embeddingModelProvider.modelProvider" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="embeddingModelProvider.bedrock.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="embeddingModelProvider.bedrock.secretKey" />
            <zeebe:input source="{{secrets.AWS_REGION}}" target="embeddingModelProvider.bedrock.region" />
            <zeebe:input source="TitanEmbedTextV2" target="embeddingModelProvider.bedrock.modelName" />
            <zeebe:input source="D1024" target="embeddingModelProvider.bedrock.dimensions" />
            <zeebe:input source="=false" target="embeddingModelProvider.bedrock.normalize" />
            <zeebe:input source="=3" target="embeddingModelProvider.bedrock.maxRetries" />
            <zeebe:input source="amazonManagedOpenSearchStore" target="vectorStore.storeType" />
            <zeebe:input source="{{secrets.AWS_VECTOR_ACCESS}}" target="vectorStore.amazonManagedOpensearch.accessKey" />
            <zeebe:input source="{{secrets.AWS_VECTOR_SECRET}}" target="vectorStore.amazonManagedOpensearch.secretKey" />
            <zeebe:input source="{{secrets.AWS_LONGTERM_MEM}}" target="vectorStore.amazonManagedOpensearch.serverUrl" />
            <zeebe:input source="{{secrets.AWS_REGION}}" target="vectorStore.amazonManagedOpensearch.region" />
            <zeebe:input source="=&#34;tech-stuff-knowagebase&#34;" target="vectorStore.amazonManagedOpensearch.indexName" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="2" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.EmbeddingsVectorDB.v1" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="errorExpression" value="=if contains(error.message, &#34;index_not_found&#34;) then bpmnError(&#34;index_not_found&#34;, &#34;The index does not exist&#34;) else null" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:boundaryEvent id="Event_13nfdh6" attachedToRef="Activity_1ftg0az">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;searchResult&#34; :&#34;Nothing was found&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_0pwwn88" />
      </bpmn:boundaryEvent>
      <bpmn:scriptTask id="Activity_1wck987" name="Get the Current Time and date">
        <bpmn:documentation>Use this tool to find out the current time and date</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=now()" resultVariable="timeAndDate" />
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;TheTimeAndDate&#34; : timeAndDate&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
    </bpmn:adHocSubProcess>
    <bpmn:startEvent id="Event_0kr9ms2" name="Info From Slack" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.MessageStartEvent.v1" zeebe:modelerTemplateVersion="7" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:slack-webhook:1" />
          <zeebe:property name="inbound.context" value="{{secrets.SLACK_HAWK_WEBHOOK_ID}}" />
          <zeebe:property name="inbound.slackSigningSecret" value="{{secrets.SLACK_HAWK_SIGINING_SECRET}}" />
          <zeebe:property name="inbound.verificationExpression" value="=if (body.type != null and body.type = &#34;url_verification&#34;) then {body:{&#34;challenge&#34;:body.challenge}, statusCode: 200} else null" />
          <zeebe:property name="activationCondition" value="=request.body.event.type = &#34;app_mention&#34;&#10;and not(is defined(request.headers.x-slack-retry-num))" />
          <zeebe:property name="consumeUnmatchedEvents" value="false" />
          <zeebe:property name="correlationRequired" value="notRequired" />
          <zeebe:property name="deduplicationModeManualFlag" value="false" />
          <zeebe:property name="deduplicationMode" value="AUTO" />
          <zeebe:property name="resultVariable" value="question" />
          <zeebe:property name="resultExpression" value="={&#10;  &#34;slackRequest&#34; : {&#10;    &#34;senderId&#34;: request.body.event.user,&#10;    &#34;channelId&#34;: request.body.event.channel,&#10;    &#34;threadTs&#34;: request.body.event.ts,&#10;    &#34;text&#34;: request.body.event.text&#10;  }&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1890yp5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0bwlass" messageRef="Message_1frfkks" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1890yp5" sourceRef="Event_0kr9ms2" targetRef="Activity_1jbvj8d" />
  </bpmn:process>
  <bpmn:message id="Message_1frfkks" name="18bce8fd-2dcf-4ad3-b237-d2fd691b1e72" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.MessageStartEvent.v1" />
  <bpmn:message id="Message_1ej24bd" name="2e3a2e04-13d9-41eb-9259-7df98ec38618" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.IntermediateCatchEvent.v1">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(slackRequest.threadTs)" />
    </bpmn:extensionElements>
  </bpmn:message>
